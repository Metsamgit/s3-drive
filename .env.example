# Copie en .env et ajuste.

# 32 octets base64. openssl rand -base64 32
SESSION_KEY=

BIND_ADDR=127.0.0.1:8080

# True seulement s'il y a vraiment un proxy devant (sinon un client
# peut faire croire qu'il est en HTTPS via X-Forwarded-Proto).
BEHIND_PROXY=true

MAX_UPLOAD_MB=100

# debug | info | warn | error
LOG_LEVEL=info

# TLS direct (laisser vide derrière nginx)
# TLS_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# TLS_KEY=/etc/letsencrypt/live/example.com/privkey.pem
