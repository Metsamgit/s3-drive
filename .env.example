# Local dev config. Copy to .env and adjust.
# Required in production.

# 32 random bytes, base64-encoded. Sessions are re-encrypted at rest with
# this. Generate with: openssl rand -base64 32
SESSION_KEY=

# Bind address. 127.0.0.1 only behind a TLS-terminating proxy.
BIND_ADDR=127.0.0.1:8080

# Trust X-Forwarded-Proto from the proxy in front. Only enable if there
# really is one (otherwise a client can fake HTTPS just by setting the
# header).
BEHIND_PROXY=true

# Max upload size in MB.
MAX_UPLOAD_MB=100

# debug | info | warn | error
LOG_LEVEL=info

# Optional direct TLS. Leave empty when behind nginx.
# TLS_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# TLS_KEY=/etc/letsencrypt/live/example.com/privkey.pem
